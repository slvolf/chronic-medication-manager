.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/
.reasonix/

### OS files ###
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

### Node (if any tooling) ###
node_modules/

